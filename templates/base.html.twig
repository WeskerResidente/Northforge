<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Northforge{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🃏</text></svg>">
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body>
        {% block header %}
        <header class="site-header">
            <div class="site-header__brand">
                <a class="site-header__logo-link" href="{{ path('app_home') }}" aria-label="Northforge accueil">
                    <img class="site-header__logo" src="{{ asset('images/logo.png') }}" alt="Northforge">
                </a>
            </div>

            <nav class="site-header__nav" aria-label="Navigation principale">
                <a class="site-header__nav-link is-active" href="{{ path('app_home') }}">
                    <img src="{{ asset('icons/home-w.svg') }}" alt="" aria-hidden="true">
                    <span>Accueil</span>
                </a>

                <a class="site-header__nav-link" href="#catalogue">
                    <img src="{{ asset('icons/shop.svg') }}" alt="" aria-hidden="true">
                    <span>Catalogue</span>
                </a>

                {% if app.user %}
                    <a class="site-header__nav-link" href="#ajouter">
                        <img src="{{ asset('icons/Add.svg') }}" alt="" aria-hidden="true">
                        <span>Ajouter</span>
                    </a>

                    <a class="site-header__nav-link" href="{{ path('app_inventory_management') }}">
                        <img src="{{ asset('icons/profil.svg') }}" alt="" aria-hidden="true">
                        <span>Profil</span>
                    </a>
                {% else %}
                    <a class="site-header__nav-link site-header__nav-link--auth" href="{{ path('app_login') }}">
                        <span>Connexion / Inscription</span>
                    </a>
                {% endif %}
            </nav>
        </header>
        {% endblock %}
        {% block body %}{% endblock %}

        {% block footer %}
        <footer class="site-footer">
            <div class="site-footer__inner">
                <div class="site-footer__brand">
                    <img class="site-footer__logo" src="{{ asset('images/logo.png') }}" alt="Northforge">
                    <p class="site-footer__text">
                        Northforge accompagne vos échanges avec une interface simple, claire et rapide.
                    </p>
                </div>

                <nav class="site-footer__nav" aria-label="Navigation secondaire">
                    <a class="site-footer__link" href="{{ path('app_privacy') }}">Politique de confidentialite</a>
                    <a class="site-footer__link" href="{{ path('app_terms') }}">Conditions d utilisation</a>
                    <a class="site-footer__link" href="{{ path('app_cookies') }}">Politique de cookies</a>
                </nav>

                <p class="site-footer__copyright">
                    &copy; {{ "now"|date("Y") }} Northforge. Tous droits réservés.
                </p>
            </div>
        </footer>
        {% endblock %}
    </body>
</html>
