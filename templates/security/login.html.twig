{% extends 'base.html.twig' %}

{% block title %}Connexion - Northforge{% endblock %}

{% block body %}
<main class="register-page">
	<section class="register-card login-card" aria-labelledby="login-title">
		<div class="register-card__header">
			<h1 class="register-card__title" id="login-title">Connexion</h1>
			<p class="register-card__subtitle">Accédez à votre espace Northforge.</p>
		</div>

		{% if error %}
			<p class="login-card__alert">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
		{% endif %}

		{% if app.user %}
			<p class="login-card__notice">
				Vous êtes connecté avec {{ app.user.userIdentifier }}.
				<a href="{{ path('app_logout') }}">Se déconnecter</a>
			</p>
		{% else %}
			<form class="register-form login-form" method="post">
				<div class="register-form__field">
					<label for="username">Mail</label>
					<input type="email" value="{{ last_username }}" name="_username" id="username" autocomplete="email" required autofocus>
				</div>

				<div class="register-form__field">
					<label for="password">Mot de passe</label>
					<input type="password" name="_password" id="password" autocomplete="current-password" required>
				</div>

				<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

				<button class="btn btn-inscription login-form__submit" type="submit">Se connecter</button>
			</form>

			<p class="login-card__register">
				Pas encore de compte ?
				<a href="{{ path('app_register') }}">Créer un compte</a>
			</p>
		{% endif %}
	</section>
</main>
{% endblock %}
